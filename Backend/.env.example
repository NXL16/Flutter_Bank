PORT=8080
SERVER_MODE=development

MYSQL_USER=root
MYSQL_PASSWORD=change_me
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=nfbank_mysql

MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=nfbank_mongo


ACCESS_TOKEN_SECRET=replace_with_a_long_random_secret
REFRESH_TOKEN_SECRET=replace_with_a_different_long_random_secret
CSRF_SECRET=replace_with_another_long_random_secret

APP_URL=http://localhost:8080
FIREBASE_CREDENTIALS=./internal/config/firebase-adminsdk.json

# Chỉ bật trên máy phát triển. Production phải để false.
ENABLE_DEV_SEED=true
ENABLE_OTP_DEBUG=false
ALLOW_TEST_PAYMENT_OTP=false

TRANSFER_MIN_AMOUNT=10000
TRANSFER_MAX_AMOUNT=500000000
DAILY_TRANSFER_LIMIT=1000000000
