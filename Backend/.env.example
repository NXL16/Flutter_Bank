# Cần giá trị biến môi trường liên hệ cho anh Lĩnh nhé !!

# Server
PORT=8080
SERVER_MODE=development
APP_URL=http://localhost:8080

# MySQL
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB=nfbank

# Generate two different random secrets of at least 32 characters.
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=

# Firebase Admin SDK
FIREBASE_CREDENTIALS=./internal/config/firebase-adminsdk.json

# Cloudinary (all three values are required for avatar uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Development-only features
ENABLE_DEV_SEED=true
ALLOW_TEST_PAYMENT_OTP=false

# Transfer limits in VND
TRANSFER_MIN_AMOUNT=10000
TRANSFER_MAX_AMOUNT=500000000
DAILY_TRANSFER_LIMIT=1000000000
ADMIN_DEPOSIT_MAX_AMOUNT=5000000000

# Savings maturity worker
SAVINGS_MATURITY_INTERVAL_SECONDS=60
